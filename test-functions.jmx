<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="MockJutsu Function Test" enabled="true">
      <boolProp name="TestPlan.functional_mode">false</boolProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Tests" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 1: cardnum (minimal)" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum)}').execute()
log.info("Test 1 cardnum: " + result)
SampleResult.setResponseData("cardnum=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.length() &gt;= 13)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 2: cardnum:visa (qualifier)" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum:visa)}').execute()
log.info("Test 2 cardnum:visa: " + result)
SampleResult.setResponseData("cardnum:visa=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.startsWith("4"))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 3: pipe — cardnum:visa|mask" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum:visa|mask)}').execute()
log.info("Test 3 pipe mask: " + result)
SampleResult.setResponseData("pipe_masked=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.contains("*"))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 4: pipe — cardnum:visa|TR|mask" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum:visa|TR|mask)}').execute()
log.info("Test 4 pipe TR+mask: " + result)
SampleResult.setResponseData("pipe_tr_masked=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.contains("*"))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 5: pipe — tckn|TR" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_identity(tckn|TR)}').execute()
log.info("Test 5 tckn: " + result)
SampleResult.setResponseData("tckn=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.length() == 11)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 6: pipe — varName storage" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum|TR|myCard)}').execute()
def stored = vars.get("myCard")
log.info("Test 6 varName: result=" + result + " stored=" + stored)
SampleResult.setResponseData("result=" + result + " stored=" + stored, "UTF-8")
SampleResult.setSuccessful(result != null &amp;&amp; result == stored)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 7: pipe — all options cardnum:visa|TR|myCard2|mask" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_financial(cardnum:visa|TR|myCard2|mask)}').execute()
def stored = vars.get("myCard2")
log.info("Test 7 all options: result=" + result + " stored=" + stored)
SampleResult.setResponseData("result=" + result + " stored=" + stored, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.contains("*") &amp;&amp; result == stored)</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 8: pipe — iban|TR" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_banking(iban|TR)}').execute()
log.info("Test 8 iban: " + result)
SampleResult.setResponseData("iban=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.startsWith("TR"))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test 9: pipe — tckn|TR|mask" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.engine.util.CompoundVariable
def result = new CompoundVariable('${__mockjutsu_identity(tckn|TR|mask)}').execute()
log.info("Test 9 tckn masked: " + result)
SampleResult.setResponseData("tckn_masked=" + result, "UTF-8")
SampleResult.setSuccessful(!result.startsWith("ERROR") &amp;&amp; result.contains("*"))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
